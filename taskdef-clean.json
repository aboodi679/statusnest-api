{
  "family": "statusnest-dev-auth",
  "taskRoleArn": "arn:aws:iam::026243800492:role/statusnest-dev-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::026243800492:role/statusnest-dev-ecs-execution-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "auth",
      "image": "026243800492.dkr.ecr.us-east-1.amazonaws.com/statusnest-dev-auth:465844160a070fee14ba6880629525d270dd02ac",
      "essential": true,
      "portMappings": [{"containerPort": 8000, "hostPort": 8000, "protocol": "tcp"}],
      "environment": [
        {"name": "JWT_ALGORITHM", "value": "HS256"},
        {"name": "JWT_EXPIRE_MINUTES", "value": "30"},
        {"name": "REDIS_URL", "value": "redis://statusnest-dev-redis.b8x2ra.0001.use1.cache.amazonaws.com:6379"}
      ],
      "secrets": [
        {"name": "JWT_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-1:026243800492:secret:statusnest-dev-jwt-secret-Ze5Tcs:value::"},
        {"name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-1:026243800492:secret:statusnest-dev-database-url-75QRll"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/statusnest-dev-auth",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "auth"
        }
      }
    }
  ]
}
